# --- Model checkpoints, weights, exported graphs (never commit large binaries) ---
*.pth
*.pt
*.ckpt
*.safetensors
*.onnx
*.engine
*.plan
*.trt
*.mlmodel
*.tflite
*.pb
*.h5

# Packed / archive artifacts often used for model releases (uncomment if you never commit these)
# *.tar
# *.zip

# Common local dirs that accumulate downloaded checkpoints (explicit; does not rely on *.pth only)
**/pretrain_weights/
**/pretrained/
**/checkpoint*/
**/weights/

# --- Benchmark outputs (recorded frames, per-run CSVs, depth/disparity dumps) ---
# All model runners under DEPTH_BENCHMARK.md write their --record-dir / --log
# artifacts into a sibling 'results/' (per-model) or 'output/' directory.
# These are large (~MBs per frame) and meant to be regenerated, never committed.
**/results/
**/output/

# --- Vendored-repo example videos (not needed for inference / training) ---
*.mp4
*.mov
*.avi
*.mkv
*.webm

# Python / tooling noise
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.so
.Python
.idea/
.vscode/
.DS_Store

# Jupyter
.ipynb_checkpoints/
